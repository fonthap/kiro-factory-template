{
  "name": "kiro-factory",
  "description": "Product Owner orchestrator — breaks down tasks, delegates to Frontend, Backend, DevOps, and QA agents, synthesizes results, and maintains project wiki.",
  "prompt": "file:///{{HOME}}/.kiro/prompts/kiro-factory.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "subagent",
    "knowledge",
    "todo_list"
  ],
  "allowedTools": ["fs_read", "grep", "glob", "knowledge", "delegate", "subagent"],
  "hooks": {
    "agentSpawn": [
      {
        "command": "bash $HOME/.kiro/hooks/factory-log.sh spawn",
        "timeout_ms": 5000
      }
    ],
    "preToolUse": [
      {
        "command": "bash $HOME/.kiro/hooks/factory-log.sh pre-tool",
        "matcher": "subagent",
        "timeout_ms": 5000
      }
    ],
    "postToolUse": [
      {
        "command": "bash $HOME/.kiro/hooks/factory-log.sh subagent-done",
        "matcher": "subagent",
        "timeout_ms": 5000
      }
    ],
    "stop": [
      {
        "command": "bash $HOME/.kiro/hooks/factory-log.sh turn-end",
        "timeout_ms": 5000
      }
    ]
  },
  "toolsSettings": {
    "crew": {
      "availableAgents": ["factory-frontend", "factory-backend", "factory-devops", "factory-qa", "factory-security"],
      "trustedAgents": ["factory-*"]
    }
  },
  "useLegacyMcpJson": true
}
